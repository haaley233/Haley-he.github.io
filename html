        .timeline-role {
            font-size: 14px;
            color: var(--text-secondary);
            margin-bottom: 16px;
        }

        .timeline-points {
            list-style: none;
        }

        .timeline-points li {
            position: relative;
            padding-left: 20px;
            margin-bottom: 8px;
            color: var(--text-secondary);
            font-size: 14px;
            line-height: 1.7;
        }

        .timeline-points li::before {
            content: '';
            position: absolute;
            left: 0;
            top: 10px;
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--border-glass);
        }

