        .projects {
            background: transparent;
            position: relative;
        }

        .projects-bento {
            grid-template-columns: repeat(3, 1fr);
            grid-template-rows: auto;
        }

        .projects-bento .bento-item:nth-child(1) {
            grid-column: span 2;
